# Copy to .env.local for local/docker runs — DO NOT commit secrets

HOST=0.0.0.0
PORT=8000
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

APP_NAME=Production AI Agent
APP_VERSION=1.0.0

OPENAI_API_KEY=
MODEL_NAME=mock-agent

AGENT_API_KEY=secret

RATE_LIMIT_PER_MINUTE=10
MONTHLY_BUDGET_USD=10
COST_PER_REQUEST_USD=0.001

# Local dev (redis on localhost). Docker Compose overrides to redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0
REDIS_CONNECT_RETRIES=15
REDIS_CONNECT_RETRY_DELAY=2

ALLOWED_ORIGINS=*
